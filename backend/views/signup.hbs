<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sign Up</title>
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap" rel="stylesheet">
    
    <!-- Link to your CSS file -->
    <link rel="stylesheet" href="/public/styles.css">
</head>
<body class="signup-page">
            <div class="signup-box">
            <h2 style="margin-left: 115px;">Register</h2>
            <form action="/register" method="POST">
                <div class="input-group">
                    <label for="firstname">First Name</label>
                    <input type="text" id="firstname" placeholder="First Name" required name="fname">
                </div>
                <div class="input-group">
                    <label for="Lastname">First Name</label>
                    <input type="text" id="Last Name" placeholder="Last Name" required name="lastname">
                </div>

                <div class="input-group">
                    <label for="email">Email</label>
                    <input type="email" id="email" placeholder="Email" required name="email">
                </div>

                <div class="input-group">
                    <label for="password">Password</label>
                    <input type="password" id="password" required name="password">
                </div>

                <div class="input-group">
                    <label for="passwordConfirm">Confirm Password</label>
                    <input type="password" id="passwordConfirm" required name="passwordConfirm">
                </div>
                <button type="submit" class="register-btn">Register</button>
             
            </form>
            <div class="separator">
                <hr>
                <span>or</span>
                <hr>
            </div>
            <p class="signup-link">Already have an account?
                 <a href="/">Sign in</a>
            </p>
        </div>
        {{#if message}}
       
            <h4 class="alert alert-danger mt-4"> {{message}} 
            </h4>
        {{/if}}
</body>
</html>
